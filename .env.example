# Supabase — crée un projet gratuit sur https://supabase.com
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=votre_anon_key_ici

# Port du serveur (Render le définit automatiquement)
PORT=3000

# Clé secrète pour protéger l'endpoint /scrape manuel
SCRAPE_SECRET=changez_ce_secret

# Optionnel : activer les logs détaillés
DEBUG=false
